{
  "name": "chipotle-llm-provider",
  "version": "1.0.0",
  "description": "OpenAI-compatible LLM proxy backed by Chipotle's Pepper AI (IPsoft Amelia)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn src/index.ts",
    "verify:runtime": "npm run build && node script/verify-runtime.js",
    "verify:retail": "npm run build && node script/verify-retail.js && node script/verify-runtime.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "tough-cookie": "^4.1.3",
    "axios-cookiejar-support": "^4.0.7",
    "ws": "^8.16.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/tough-cookie": "^4.0.5",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
